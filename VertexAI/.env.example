# Copy this file to .env before running docker compose.

# Google Cloud / Vertex AI
PROJECT_ID=copper-affinity-467409-k7
GCP_KEY_PATH=./GCPKey/copper-affinity-467409-k7-7ba2e06ec019.json

# Firebase Auth. Leave FIREBASE_PROJECT_ID empty when it is the same as PROJECT_ID.
FIREBASE_PROJECT_ID=my-agent-app-a5e42
FIREBASE_API_KEY=AIzaSyByXo24VBE5-cAGsQ4z56DElz-JjsIwgZ4
FIREBASE_AUTH_DOMAIN=my-agent-app-a5e42.firebaseapp.com
FIREBASE_APP_ID=1:832798443183:web:492dffdff626ba9855765a
FIREBASE_MEASUREMENT_ID=G-Z3249K0Y0H

# Firestore persistence.
FIRESTORE_PROJECT_ID=my-agent-app-a5e42

# Public URL used in verification and password reset emails.
APP_BASE_URL=http://localhost:8880

# Published host port.
WEB_PORT=8880

# Default provider shown in the standalone web client.
DEFAULT_PROVIDER_ID=gemini

# Optional OpenAI-compatible provider. Works with OpenAI-compatible /chat/completions endpoints.
OPENAI_COMPATIBLE_ENABLED=false
OPENAI_COMPATIBLE_ENDPOINT=https://api.openai.com/v1/chat/completions
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4.1-mini

# Optional provider API keys. Setting a key enables the matching provider template in appsettings.json.
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
XIAOMI_MIMO_API_KEY=
