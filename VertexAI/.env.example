# Copy this file to .env before running docker compose.

# Google Cloud / Vertex AI
PROJECT_ID=your-google-cloud-project
GCP_KEY_PATH=./GCPKey/credentials.json

# PostgreSQL
DB_PASSWORD=replace-this-password

# Public URL used in verification and password reset emails.
APP_BASE_URL=http://localhost:8880

# Optional SMTP settings. Leave empty to skip email sending in local development.
SMTP_USER=
SMTP_PASSWORD=
