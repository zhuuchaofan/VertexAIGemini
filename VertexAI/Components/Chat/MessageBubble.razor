@* 单条消息气泡组件 - 增强版 *@
@inject IJSRuntime JS

<div class="@(IsUser ? "flex justify-end" : "flex justify-start") animate-fadeIn group/msg">
    <div class="max-w-[85%] @(IsUser
        ? "bg-slate-950 text-white rounded-lg shadow-sm"
        : "bg-white border border-slate-200 text-slate-800 rounded-lg shadow-sm") px-4 py-3 transition-all hover:shadow-md relative">

        @if (!IsUser && ThinkingContent?.Length > 0)
        {
            <details class="mb-3 group">
                <summary class="cursor-pointer text-xs text-slate-500 hover:text-slate-900 flex items-center gap-1.5 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>
                    </svg>
                    <span>思考过程</span>
                    <span class="text-slate-400">(@ThinkingContent.Length 字符)</span>
                </summary>
                <div class="mt-2 pl-3 text-xs text-slate-600 border-l-2 border-slate-300 whitespace-pre-wrap bg-slate-50 rounded-r py-2 pr-2">
                    @ThinkingContent
                </div>
            </details>
        }

        @if (IsUser)
        {
            @* 用户消息：显示附加的图片 *@
            @if (Attachments?.Count > 0)
            {
                <div class="flex flex-wrap gap-2 mb-2">
                    @foreach (var img in Attachments)
                    {
                        <img src="@img.DataUrl"
                             alt="上传的图片"
                             class="max-w-[220px] max-h-[160px] rounded-md shadow-sm cursor-pointer hover:opacity-90 transition-opacity"
                             @onclick="() => OpenImagePreview(img.DataUrl)" />
                    }
                </div>
            }
            <div class="whitespace-pre-wrap break-words text-sm leading-relaxed">@Content</div>
        }
        else
        {
            <div class="markdown-body text-sm leading-relaxed">
                @((MarkupString)MarkdownHtml)
                @if (IsStreaming)
                {
                    <span class="inline-block w-2 h-5 bg-sky-400 ml-1 rounded-sm cursor-blink"></span>
                }
            </div>

            @* 连网搜索来源引用 *@
            @if (Citations?.Count > 0)
            {
                <div class="mt-4 pt-3 border-t border-slate-100 flex flex-wrap gap-2 animate-[fadeIn_0.3s_ease-out]">
                    <span class="text-xs text-slate-400 font-medium flex items-center gap-1">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                        </svg>
                        来源引用:
                    </span>
                    @foreach (var cite in Citations)
                    {
                        <a href="@cite.Uri" target="_blank" rel="noopener noreferrer"
                           class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-slate-100 hover:bg-slate-200 hover:text-slate-900 rounded-full text-xs text-slate-600 font-medium transition-all max-w-[200px] truncate"
                           title="@cite.Title">
                            <span class="truncate">@cite.Title</span>
                            <svg class="w-2.5 h-2.5 flex-shrink-0 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                            </svg>
                        </a>
                    }
                </div>
            }

            @* 复制按钮 - AI 消息专属 *@
            @if (!IsStreaming && !string.IsNullOrEmpty(Content))
            {
                <div class="flex items-center gap-1 mt-2 pt-2 border-t border-slate-100">
                    <button @onclick="CopyContent"
                            class="flex items-center gap-1 px-2 py-1 text-xs text-slate-400 hover:text-slate-900 hover:bg-slate-100 rounded-md transition-all opacity-0 group-hover/msg:opacity-100"
                            title="复制">
                        @if (_copied)
                        {
                            <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                            </svg>
                            <span class="text-emerald-500">已复制</span>
                        }
                        else
                        {
                            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                            </svg>
                            <span>复制</span>
                        }
                    </button>
                </div>
            }
        }
    </div>
</div>

<style>
    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [Parameter] public bool IsUser { get; set; }
    [Parameter] public string Content { get; set; } = "";
    [Parameter] public string? ThinkingContent { get; set; }
    [Parameter] public bool IsStreaming { get; set; }
    [Parameter] public string MarkdownHtml { get; set; } = "";
    [Parameter] public List<ImageAttachment>? Attachments { get; set; }
    [Parameter] public List<SearchCitation>? Citations { get; set; }
    [Parameter] public EventCallback<string> OnImageClick { get; set; }

    private bool _copied;

    private async Task OpenImagePreview(string dataUrl)
    {
        await OnImageClick.InvokeAsync(dataUrl);
    }

    private async Task CopyContent()
    {
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", Content);
            _copied = true;
            StateHasChanged();
            await Task.Delay(2000);
            _copied = false;
            StateHasChanged();
        }
        catch { /* clipboard API 不可用 */ }
    }
}

